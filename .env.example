# =============================================================================
# Bosch eBike Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to git — it contains your secrets.
# =============================================================================

# Step 1: Register at https://portal.bosch-ebike.com/data-act/app
# Use redirect URI: http://localhost:3000/api/auth/callback/bosch
AUTH_BOSCH_CLIENT_ID=
AUTH_BOSCH_CLIENT_SECRET=

# Step 2: Generate a random secret (run: npx auth secret)
AUTH_SECRET=

# These are the same for everyone — no changes needed
AUTH_BOSCH_ISSUER=https://p9.authz.bosch.com/auth/realms/obc
BOSCH_API_BASE_URL=https://api.bosch-ebike.com
NEXTAUTH_URL=http://localhost:3000

# Optional: Your bike image URL
# Find your bike's image in the eBike Flow app or manufacturer's website.
# Leave empty to show a generic eBike silhouette.
# Example for Cube bikes:
# BIKE_IMAGE_URL=https://cdn.interface-obc-s3.prod.connected-biking.cloud/CUB-CUB-CUBE/...
BIKE_IMAGE_URL=
